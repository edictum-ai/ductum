{
  "name": "@ductum/cli",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "bin": {
    "ductum": "./dist/index.js"
  },
  "files": [
    "dist"
  ],
  "engines": {
    "node": ">=22"
  },
  "scripts": {
    "build": "pnpm --filter @ductum/core build && tsc -p tsconfig.json && chmod +x dist/index.js",
    "test": "vitest run",
    "lint": "tsc --noEmit -p tsconfig.json"
  },
  "dependencies": {
    "@clack/prompts": "1.2.0",
    "@ductum/core": "workspace:0.1.0",
    "commander": "14.0.3",
    "yaml": "2.8.3"
  }
}
