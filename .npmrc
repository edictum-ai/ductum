# Supply chain security hardening
# See: TeamPCP campaign (litellm, trivy, March 2026)
# See: Axios npm compromise (UNC1069/Sapphire Sleet, March 2026)

# Exact versions only — no ^ or ~ ranges.
# Prevents auto-upgrade to compromised patch releases.
save-exact=true

# Disable postinstall scripts by default.
# This is the primary execution vector for npm supply chain attacks.
# The axios attack used a malicious dependency's postinstall to drop a RAT.
ignore-scripts=true

# Require lockfile to be up-to-date. Fails if lockfile is missing or stale.
# pnpm equivalent of npm ci behavior.
frozen-lockfile=true

# Strict peer dependencies — catch version conflicts early.
strict-peer-dependencies=true

# Disallow installing packages not declared in package.json.
# Prevents phantom dependency exploitation.
hoist=false
